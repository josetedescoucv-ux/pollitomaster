{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pollito Master",
  "version": "0.0.1",
  "identifier": "com.josetedesco.pollitomaster",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pollito Master",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/josetedescoucv-ux/pollitomaster/releases/latest/download/latest.json"
]
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERDMTUzNzFCRDFDQ0ZGQjAKUldTdy84elJHemNWM0QyQVgzdUtVMnJLZHUxemk5N1RTMGZtcC9kZ1JIOHpYenlxbmJLQ0Y5MHgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
